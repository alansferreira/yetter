{
  "name": "yaml-setter",
  "version": "1.0.2",
  "description": "A YAML update library with multi-document support and typed JSONPath-like node setters.",
  "type": "commonjs",
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "build": "webpack --config webpack.config.cjs",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:debug": "vitest --run --inspect-brk",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "dotenv": "^17.2.3",
    "lodash": "^4.17.23",
    "uuid": "^13.0.0",
    "xior": "^0.1.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.23",
    "@types/node": "^20.10.0",
    "copy-webpack-plugin": "^13.0.1",
    "standard-version": "^9.5.0",
    "ts-loader": "^9.5.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-bundle": "^1.0.18",
    "vitest": "^3.2.4",
    "webpack": "^5.105.0",
    "webpack-cli": "^6.0.1"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "Your Name",
  "license": "MIT"
}
